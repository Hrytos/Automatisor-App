# -- Supabase ----------------------------------------------------------------
# Project URL - found in Supabase dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key - used for client-facing auth (OTP sign-in)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role secret key - used for admin DB access (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -- Resend (transactional email) --------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Sender address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=no-reply@automatisor.com

# -- Google Maps --------------------------------------------------------------
# Used for address validation / geocoding
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -- Slack --------------------------------------------------------------------
# Incoming webhook URL for internal notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# -- Server -------------------------------------------------------------------
# Port the FastAPI/uvicorn server listens on (default: 3000)
PORT=3000

# Comma-separated list of allowed browser origins for CORS in production
# Example: https://automatisor.app,https://www.automatisor.app
CORS_ALLOW_ORIGINS=https://your-production-frontend.com

# Set to "false" in local development to allow non-HTTPS cookies
COOKIE_SECURE=true

# Set to "1" to enable dry-run mode (skips writes/side-effects)
AUTOMATISOR_DRY=0

# Set to "1" to enable local-only development trigger endpoints
ALLOW_DEV_TRIGGERS=0

# -- Stripe -------------------------------------------------------------------
# Secret key - server-only, NEVER expose to the browser
# Test keys start with sk_test_, live keys with sk_live_
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Webhook signing secret - obtained from Stripe Dashboard > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
